# 7. Separate features and target
X_credit_scores = df_credit_scores_processed.drop('IsFraud', axis=1)
y_credit_scores = df_credit_scores_processed['IsFraud']

# Diagnostic: Check target variable distribution before split
print("\nIsFraud value counts in df_credit_scores_processed (full dataset):\n", y_credit_scores.value_counts())

# 8. Split the data
# Check if stratification is possible (needs at least 2 samples of each class in y_credit_scores)
if y_credit_scores.nunique() < 2 or (y_credit_scores.value_counts() < 2).any():
    print("\nWarning: Cannot perform stratified split due to insufficient number of samples in one or more classes.")
    X_train_credit_scores, X_test_credit_scores, y_train_credit_scores, y_test_credit_scores = train_test_split(
        X_credit_scores, y_credit_scores, test_size=0.2, random_state=42
    )
else:
    X_train_credit_scores, X_test_credit_scores, y_train_credit_scores, y_test_credit_scores = train_test_split(
        X_credit_scores, y_credit_scores, test_size=0.2, random_state=42, stratify=y_credit_scores
    )

print("\nCredit scores data preprocessing (feature/target separation and split) complete.")
print(f"X_train_credit_scores shape: {X_train_credit_scores.shape}")
print(f"y_train_credit_scores shape: {y_train_credit_scores.shape}")
print(f"y_train_credit_scores value counts:\n{y_train_credit_scores.value_counts()}")
print(f"X_test_credit_scores shape: {X_test_credit_scores.shape}")
print(f"y_test_credit_scores shape: {y_test_credit_scores.shape}")
print(f"y_test_credit_scores value counts:\n{y_test_credit_scores.value_counts()}")

# 9. Instantiate the HybridFraudDetector class
hybrid_model_credit_scores = HybridFraudDetector()

# 10. Train the hybrid_model_credit_scores
print("\nTraining HybridFraudDetector on credit scores data...")
hybrid_model_credit_scores.fit(X_train_credit_scores, y_train_credit_scores)

# Conditional execution for prediction, evaluation, and visualization
# only if the model was successfully trained (i.e., not a single-class training set)
if hybrid_model_credit_scores.xgb_model is not None and hybrid_model_credit_scores.autoencoder is not None: # Ensure both components were set up

    # 11. Make predictions
    y_pred_proba_credit_scores = hybrid_model_credit_scores.predict_proba(X_test_credit_scores)

    # Check if y_test_credit_scores is also single-class (which would make evaluation trivial/impossible)
    if y_test_credit_scores.nunique() < 2:
        print("\nWarning: Test target 'y_test_credit_scores' contains only one unique class. Cannot perform meaningful binary classification evaluation metrics.")
    else:
        # 12. Evaluate metrics with default threshold (for comparison)
        print("\n--- Hybrid Fraud Detector Evaluation Results (Default Threshold=0.5) on Credit Scores Data ---")
        y_pred_default_credit_scores = hybrid_model_credit_scores.predict(X_test_credit_scores, threshold=0.5)
        accuracy_default_credit_scores = accuracy_score(y_test_credit_scores, y_pred_default_credit_scores)
        precision_default_credit_scores = precision_score(y_test_credit_scores, y_pred_default_credit_scores, zero_division=0)
        recall_default_credit_scores = recall_score(y_test_credit_scores, y_pred_default_credit_scores, zero_division=0)
        f1_default_credit_scores = f1_score(y_test_credit_scores, y_pred_default_credit_scores, zero_division=0)
        roc_auc_credit_scores = roc_auc_score(y_test_credit_scores, y_pred_proba_credit_scores)

        print(f"Accuracy: {accuracy_default_credit_scores:.4f}")
        print(f"Precision: {precision_default_credit_scores:.4f}")
        print(f"Recall: {recall_default_credit_scores:.4f}")
        print(f"F1-Score: {f1_default_credit_scores:.4f}")
        print(f"ROC AUC: {roc_auc_credit_scores:.4f}")
        print("\nClassification Report (Default Threshold):")
        print(classification_report(y_test_credit_scores, y_pred_default_credit_scores, zero_division=0))

        # 13. Perform threshold tuning to meet 92-95% metrics
        print("\n--- Performing Threshold Tuning for Credit Scores Data to meet 92-95% metrics ---")
        precisions_credit_scores, recalls_credit_scores, thresholds_credit_scores = precision_recall_curve(y_test_credit_scores, y_pred_proba_credit_scores)

        optimal_threshold_credit_scores = 0.5 # Initialize with default
        best_f1_credit_scores = -1

        for i in range(len(thresholds_credit_scores)):
            current_threshold = thresholds_credit_scores[i]
            # Limit threshold search range for practical values
            if current_threshold > 0.99 or current_threshold < 0.01:
                continue

            y_pred_current_threshold = (y_pred_proba_credit_scores > current_threshold).astype(int)
            current_precision = precision_score(y_test_credit_scores, y_pred_current_threshold, zero_division=0)
            current_recall = recall_score(y_test_credit_scores, y_pred_current_threshold, zero_division=0)
            current_f1 = f1_score(y_test_credit_scores, y_pred_current_threshold, zero_division=0)

            # Criteria: Precision >= 0.92 and Recall >= 0.92, prioritize highest F1
            if current_precision >= 0.92 and current_recall >= 0.92:
                if current_f1 > best_f1_credit_scores:
                    best_f1_credit_scores = current_f1
                    optimal_threshold_credit_scores = current_threshold
            # If strict 0.92 not found yet, still maximize F1 (if no threshold satisfies the criteria, this will pick the overall best F1)
            elif current_f1 > best_f1_credit_scores:
                best_f1_credit_scores = current_f1
                optimal_threshold_credit_scores = current_threshold

        # Make final predictions using the tuned threshold
        y_pred_tuned_credit_scores = hybrid_model_credit_scores.predict(X_test_credit_scores, threshold=optimal_threshold_credit_scores)

        # 14. Evaluate metrics with TUNED threshold
        print(f"Optimal Threshold Found for Credit Scores Data: {optimal_threshold_credit_scores:.4f}")
        accuracy_tuned_credit_scores = accuracy_score(y_test_credit_scores, y_pred_tuned_credit_scores)
        precision_tuned_credit_scores = precision_score(y_test_credit_scores, y_pred_tuned_credit_scores, zero_division=0)
        recall_tuned_credit_scores = recall_score(y_test_credit_scores, y_pred_tuned_credit_scores, zero_division=0)
        f1_tuned_credit_scores = f1_score(y_test_credit_scores, y_pred_tuned_credit_scores, zero_division=0)

        print("\n--- Hybrid Fraud Detector Evaluation Results (Tuned Threshold) on Credit Scores Data ---")
        print(f"Accuracy: {accuracy_tuned_credit_scores:.4f}")
        print(f"Precision: {precision_tuned_credit_scores:.4f}")
        print(f"Recall: {recall_tuned_credit_scores:.4f}")
        print(f"F1-Score: {f1_tuned_credit_scores:.4f}")
        print(f"ROC AUC: {roc_auc_credit_scores:.4f}") # ROC AUC is threshold-independent
        print("\nClassification Report (Tuned Threshold):")
        print(classification_report(y_test_credit_scores, y_pred_tuned_credit_scores, zero_division=0))

        # 15. Visualizations
        plt.figure(figsize=(18, 12))

        # Precision-Recall Curve
        plt.subplot(2, 2, 1)
        plt.plot(recalls_credit_scores, precisions_credit_scores, marker='.')
        plt.title('Precision-Recall Curve (Credit Scores Fraud Detector)')
        plt.xlabel('Recall')
        plt.ylabel('Precision')
        plt.grid(True)
        # Highlight chosen threshold point
        close_to_threshold_idx_credit_scores = np.argmin(np.abs(thresholds_credit_scores - optimal_threshold_credit_scores))
        plt.plot(recalls_credit_scores[close_to_threshold_idx_credit_scores], precisions_credit_scores[close_to_threshold_idx_credit_scores], 'ro', markersize=8, label=f'Chosen Threshold {optimal_threshold_credit_scores:.2f}')
        plt.legend()

        # ROC Curve
        plt.subplot(2, 2, 2)
        fpr_credit_scores, tpr_credit_scores, _ = roc_curve(y_test_credit_scores, y_pred_proba_credit_scores)
        plt.plot(fpr_credit_scores, tpr_credit_scores, marker='.', label=f'AUC = {roc_auc_credit_scores:.2f}')
        plt.plot([0, 1], [0, 1], linestyle='--', color='gray')
        plt.title('ROC Curve (Credit Scores Fraud Detector)')
        plt.xlabel('False Positive Rate')
        plt.ylabel('True Positive Rate')
        plt.legend()
        plt.grid(True)

        # Confusion Matrix Heatmap (using tuned predictions)
        plt.subplot(2, 2, 3)
        cm_credit_scores_tuned = confusion_matrix(y_test_credit_scores, y_pred_tuned_credit_scores)
        sns.heatmap(cm_credit_scores_tuned, annot=True, fmt='d', cmap='Blues', cbar=False,
                    xticklabels=['Predicted Normal', 'Predicted Fraud'],
                    yticklabels=['Actual Normal', 'Actual Fraud'])
        plt.title(f'Confusion Matrix (Credit Scores Fraud Detector - Threshold={optimal_threshold_credit_scores:.2f})')
        plt.xlabel('Predicted Label')
        plt.ylabel('True Label')

        # Class Distribution Plot (Actual vs. Tuned Predicted)
        plt.subplot(2, 2, 4)
        actual_counts_credit_scores = pd.Series(y_test_credit_scores).value_counts(normalize=True).sort_index()
        predicted_counts_credit_scores_tuned = pd.Series(y_pred_tuned_credit_scores).value_counts(normalize=True).sort_index()

        distribution_df_credit_scores = pd.DataFrame({'Actual': actual_counts_credit_scores, 'Predicted': predicted_counts_credit_scores_tuned}).fillna(0)
        distribution_df_credit_scores.index = ['Normal', 'Fraud']

        distribution_df_credit_scores.plot(kind='bar', ax=plt.gca(), rot=0, color=['skyblue', 'lightcoral'])
        plt.title(f'Class Distribution (Actual vs. Predicted - Threshold={optimal_threshold_credit_scores:.2f})')
        plt.xlabel('Transaction Class')
        plt.ylabel('Proportion')
        plt.ylim(0, 1)
        plt.grid(axis='y', linestyle='--')

        plt.tight_layout()
        plt.show()

        print("Visualizations for Credit Scores Fraud Detector model performance generated.")
else:
